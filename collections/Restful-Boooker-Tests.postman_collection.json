                  "  const item = qp.find(q => (q && q.key) === key);",
                  "  if (!item) return '';",
                  "  // If value is undefined/null, normalize to empty string",
                  "  return (item.value === undefined || item.value === null) ? '' : String(item.value);",
                  "};",
                  "",
                  "const filterFirstname = getQueryValue('firstname');",
                  "const filterLastname = getQueryValue('lastname');",
                  "",
                  "pm.collectionVariables.set('filterFirstname', filterFirstname);",
                  "pm.collectionVariables.set('filterLastname', filterLastname);",
                  ""
