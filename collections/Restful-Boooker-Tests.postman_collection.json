        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.environment.get(\"authToken\")) {\r",
                  "\r",
                  "pm.sendRequest({\r",
                  "url: pm.environment.get(\"baseUrl\") + \"/auth\",\r",
                  "method: \"POST\",\r",
                  "header: {\r",
                  "\"Content-Type\": \"application/json\"\r",
                  "},\r",
                  "body: {\r",
                  "mode: \"raw\",\r",
                  "raw: JSON.stringify({\r",
                  "username: pm.environment.get(\"username\"),\r",
                  "password: pm.environment.get(\"password\")\r",
                  "})\r",
                  "}\r",
                  "}, function (err, res) {\r",
                  "\r",
                  "if (!err) {\r",
                  "var token = res.json().token;\r",
                  "pm.environment.set(\"authToken\", token);\r",
                  "console.log(\"Token generated automatically\");\r",
                  "}\r",
                  "\r",
                  "});\r",
                  "\r",
                  "}\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Booking ID exists\", function () {",
                  "    var jsonData;",
                  "    jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"bookingid\");",
                  "    pm.expect(jsonData.bookingid).to.be.a(\"number\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
