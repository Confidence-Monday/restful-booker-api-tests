            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Booking response is valid JSON and has expected shape\", function () {",
                  "    // Validate JSON",
                  "    pm.response.to.be.json;",
                  "",
                  "    const data = pm.response.json();",
                  "",
                  "    // Basic shape checks (Restful-Booker GET /booking/{id} returns a booking object without an id)",
                  "    pm.expect(data).to.be.an(\"object\");",
                  "",
                  "    pm.expect(data).to.have.property(\"firstname\");",
                  "    pm.expect(data.firstname).to.be.a(\"string\").and.not.be.empty;",
                  "",
                  "    pm.expect(data).to.have.property(\"lastname\");",
                  "    pm.expect(data.lastname).to.be.a(\"string\").and.not.be.empty;",
                  "",
                  "    pm.expect(data).to.have.property(\"totalprice\");",
                  "    pm.expect(data.totalprice).to.be.a(\"number\");",
                  "",
                  "    pm.expect(data).to.have.property(\"depositpaid\");",
                  "    pm.expect(data.depositpaid).to.be.a(\"boolean\");",
                  "",
                  "    pm.expect(data).to.have.property(\"bookingdates\");",
                  "    pm.expect(data.bookingdates).to.be.an(\"object\");",
                  "    pm.expect(data.bookingdates).to.have.property(\"checkin\");",
                  "    pm.expect(data.bookingdates.checkin).to.be.a(\"string\").and.not.be.empty;",
                  "    pm.expect(data.bookingdates).to.have.property(\"checkout\");",
                  "    pm.expect(data.bookingdates.checkout).to.be.a(\"string\").and.not.be.empty;",
                  "",
                  "    // additionalneeds can be optional in some implementations; if present, validate type",
                  "    if (Object.prototype.hasOwnProperty.call(data, \"additionalneeds\") && data.additionalneeds !== null) {",
                  "        pm.expect(data.additionalneeds).to.be.a(\"string\");",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"Booking ID variable is present and non-empty\", function () {",
                  "    const bookingIdVar = pm.variables.get(\"bookingId\");",
                  "    pm.expect(bookingIdVar, \"bookingId variable must be set\").to.exist;",
                  "    pm.expect(String(bookingIdVar), \"bookingId variable must not be empty\").to.not.equal(\"\");",
                  "});",
                  "",
                  "pm.test(\"If response contains an id field, it matches bookingId variable\", function () {",
                  "    const data = pm.response.json();",
                  "    const bookingIdVar = pm.variables.get(\"bookingId\");",
                  "",
                  "    if (data && Object.prototype.hasOwnProperty.call(data, \"bookingid\")) {",
                  "        pm.expect(String(data.bookingid)).to.equal(String(bookingIdVar));",
                  "    } else if (data && Object.prototype.hasOwnProperty.call(data, \"id\")) {",
                  "        pm.expect(String(data.id)).to.equal(String(bookingIdVar));",
                  "    } else {",
                  "        pm.expect(true).to.equal(true); // no id field to compare; pass by design",
                  "    }",
                  "});",
                  ""
                ],
